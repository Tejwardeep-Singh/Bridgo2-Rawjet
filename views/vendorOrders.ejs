<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png">
    <link rel="manifest" href="/favicon/site.webmanifest">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="stylesheet" href="/stylesheets/orders.css">
    <title>Vendor | My Orders</title>
</head>
<body>
    <nav class="navbar">
        <div class="nav-container">
            <div class="nav-left">
                <a href="/" class="nav-logo">
                    <img src="/images/logo.png" alt="Bridgo Logo">
                </a>
            </div>
            <div class="nav-right">
                <ul class="nav-menu">
                    <li><a href="/">Home</a></li>
                    <!-- <li><a href="/vendor/login" class="active">Vendor</a></li>
                    <li><a href="/supplier/login">Supplier</a></li> -->
                </button>
                </ul>
            </div>
            <div class="hamburger">
                <span></span>
                <span></span>
                <span></span>
            </div>
        </div>
    </nav>

    <div class="container">

        <!-- HERO -->
        <div class="hero">

            <h1>📦 My Orders</h1>

            <p>
                Track supplier orders, payments, and procurement status in real-time.
            </p>

        </div>

        <% if(orders.length > 0){ %>

            <div class="orders-grid">

                <% orders.forEach(order => { %>

                    <div class="order-card">

                        <div class="card-glow"></div>

                        <div class="card-top">

                            <div class="item-name">
                                <%= order.itemName %>
                            </div>

                            <div class="amount">
                                ₹ <%= order.amount %>
                            </div>

                        </div>

                        <div class="details">

                            <div class="detail">

                                <span class="label">
                                    Supplier
                                </span>

                                <span class="value">
                                    <%= order.supplierName %>
                                </span>

                            </div>

                            <div class="detail">

                                <span class="label">
                                    Quantity
                                </span>

                                <span class="value">
                                    <%= order.quantity %>
                                </span>

                            </div>

                            <div class="detail">

                                <span class="label">
                                    Order Status
                                </span>

                                <span class="
                                    badge
                                    <%= order.orderStatus %>
                                ">

                                    <%= order.orderStatus %>

                                </span>

                            </div>

                            <div class="detail">

                                <span class="label">
                                    Payment
                                </span>

                                <span class="
                                    badge
                                    <%= order.paymentStatus %>
                                ">

                                    <%= order.paymentStatus %>

                                </span>

                            </div>

                            <div class="detail">

                                <span class="label">
                                    Created
                                </span>

                                <span class="value">

                                    <%= new Date(order.createdAt)
                                        .toLocaleDateString() %>

                                </span>

                            </div>

                        </div>

                    </div>

                <% }) %>

            </div>

        <% } else { %>

            <div class="empty-state">

                <img
                    src="/images/empty-orders.svg"
                    alt="No Orders"
                >

                <h2>No Orders Yet</h2>

                <p>
                    Accepted supplier offers will appear here.
                </p>

            </div>

        <% } %>

    </div>
    <div class="footer-bottom">
            <p>&copy; 2026 Team Rawjet. All rights reserved.</p>
        </div>

</body>
</html>