                >

                    📍 Update Live Location

                </button>

            </div>
        </section>

        <nav class="dashboard-actions">
            <a href="/vendor/live-auctions" class="action-btn">🔴 Live Auctions</a>
            <a href="/vendor/auction/join" class="action-btn">➕ Ask Requirements</a>
            <a href="/vendor/my-requirements" class="action-btn">📋 My Requirements</a>
            <a href="/vendor/create-auction" class="action-btn">🏢 Create Auction</a>
            <a href="/vendor/my-auctions" class="action-btn">📊 My Auctions</a>
            <a href="/vendor/change-password" class="action-btn"> 🔒 Change Password</a>
        </nav>
        <section class="live-notifications-section">

    <div class="section-header">

        <h2>
            🔔 Live Notifications
        </h2>

        <span>
            Realtime auction activity
        </span>

    </div>

    <div
        id="liveNotificationStack"
        class="live-notification-stack"
    >

        <div class="empty-feed">

            No activity yet

        </div>

    </div>

</section>
    </div>
    
</main>

