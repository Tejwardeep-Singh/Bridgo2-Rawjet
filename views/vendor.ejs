                <div class="info-item"><label>Phone</label><span><%= vendor.phone %></span></div>
                <div class="info-item"><label>Location</label><span><%= vendor.city %>, <%= vendor.state %></span></div>
            </div>
            <div class="location-update-wrapper">
                <button
                    id="updateVendorLocationBtn"
