const socket = io();
function formatTime(date){

    const seconds =
    Math.floor(

        (new Date() - new Date(date))
        / 1000
    );


    if(seconds < 60){

        return "Just now";
    }


    const minutes =
    Math.floor(seconds / 60);

    if(minutes < 60){

        return `${minutes} min ago`;
    }


    const hours =
    Math.floor(minutes / 60);

    if(hours < 24){

        return `${hours} hr ago`;
    }


    const days =
    Math.floor(hours / 24);

    return `${days} day ago`;
}
function addNotificationToUI(

    data,

    increaseCount=true

){

    // UPDATE COUNT

    if(increaseCount){

        unreadCount++;

        notificationCount.textContent =
        unreadCount;
    }


    // REMOVE EMPTY PANEL MESSAGE

    const emptyMessage =
    document.querySelector(
        ".empty-notification"
    );

    if(emptyMessage){

        emptyMessage.remove();
    }


    // CREATE PANEL ITEM

    const notificationItem =
    document.createElement("div");

    notificationItem.classList.add(
        "notification-item"
    );


    notificationItem.innerHTML =

    `
    <div class="notification-title">
        ${data.title}
    </div>

    <div class="notification-message">
        ${data.message}
    </div>

    <div class="notification-time">
    ${formatTime(data.createdAt)}
</div>
    `;


    notificationList.prepend(
        notificationItem
    );


    // LIVE STACK

    const emptyFeed =
    document.querySelector(
        ".empty-feed"
    );

    if(emptyFeed){

        emptyFeed.remove();
    }


    const card =
    document.createElement("div");

    card.classList.add(
        "live-feed-card"
    );


    card.innerHTML =

    `
    <div class="feed-left">

        <div class="feed-icon">
            🔔
        </div>

        <div class="feed-content">

            <h3>
                ${data.title}
            </h3>

            <p>
                ${data.message}
            </p>

        </div>

    </div>

    <div class="feed-time">
    ${formatTime(data.createdAt)}
</div>
    `;


    liveStack.prepend(card);
}
