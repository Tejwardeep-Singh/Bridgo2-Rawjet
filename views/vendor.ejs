);

socket.on(

    "new-notification",

    (data)=>{

        addNotificationToUI(data);
    }
);
async function
loadNotifications(){

    try{

        const response =
        await fetch(
            "/vendor/notifications"
        );

        const notifications =
        await response.json();


        notifications.reverse()
        .forEach(data=>{

            addNotificationToUI(

                data,

                false
            );
        });

    }catch(err){

        console.log(err);
    }
}
loadNotifications();

