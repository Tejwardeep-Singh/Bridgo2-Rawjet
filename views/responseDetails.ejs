<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png">
    <link rel="manifest" href="/favicon/site.webmanifest">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="stylesheet" href="/stylesheets/vendorDetails.css">
    <title>Supplier Response Details - Bridgo</title>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar">
        <div class="nav-container">

            <a href="/" class="nav-logo">
                <img src="/images/logo.png" alt="Bridgo">
            </a>

            <div class="nav-links">
                <a href="/">Home</a>
                <a href="/vendor/orders">
                    My Orders
                </a>
                <a href="/vendor">Dashboard</a>
            </div>

        </div>
    </nav>

    <!-- Main -->
    <div class="page-container">

        <!-- Hero -->
        <div class="top-section">
            <h1>
                Supplier Offer Details
                <span class="verified">✔ Verified</span>
            </h1>

            <p>
                Review supplier details and proceed with your order securely.
            </p>
        </div>
        <div class="detail-item">
            <span class="label">Offer Status</span>

            <span class="
                <%= response.responseStatus === 'accepted'
                    ? 'accepted-status'
                    : response.responseStatus === 'rejected'
                    ? 'rejected-status'
                    : 'pending-status'
                %>
            ">

                <%= response.responseStatus.toUpperCase() %>

            </span>

        </div>

        <!-- Grid -->
        <div class="details-grid">

            <!-- Supplier Info -->
            <div class="card">

                <h2>Supplier Information</h2>
                <div class="detail-item">
                    <span class="label">Supplier Name</span>

                    <span class="value">
                        <%= response.supplierName %>
                    </span>
                </div>

                <div class="detail-item">
                    <span class="label">Phone</span>

                    <span class="value">
                        <%= response.supplierPhone %>
                    </span>
                </div>

                <div class="detail-item">
                    <span class="label">Email</span>

                    <span class="value">
                        <%= response.supplierEmail %>
                    </span>
                </div>

                <div class="detail-item">
                    <span class="label">Location</span>

                    <span class="value">
                        <%= response.supplierLocation %>
                    </span>
                </div>

                <div class="detail-item">
                    <span class="label">Response Time</span>

                    <span class="value">
                        <%= new Date(response.responseTime).toLocaleString() %>
                    </span>
                </div>

            </div>

            <!-- Requirement Info -->
            <div class="card">

                <h2>Requirement Details</h2>

                <div class="detail-item">
                    <span class="label">Item</span>

                    <span class="value">
                        <%= requirement.itemName %>
                    </span>
                </div>

                <div class="detail-item">
                    <span class="label">Required Quantity</span>

                    <span class="value">
                        <%= requirement.quantity %>
                    </span>
                </div>

                <div class="detail-item">
                    <span class="label">Supplier Quantity</span>

                    <span class="value">
                        <%= response.proposedQuantity %>
                    </span>
                </div>

                <div class="detail-item">
                    <span class="label">Status</span>

                    <span class="value">
                        <%= response.responseStatus %>
                    </span>
                </div>

                <div class="detail-item">
                    <span class="label">Delivery Estimate</span>

                    <span class="value">
                        <%= response.deliveryEstimate || "Not Mentioned" %>
                    </span>
                </div>

                <div class="detail-item">
                    <span class="label">Supplier Price</span>

                    <span class="price-tag">
                        ₹ <%= response.proposedPrice %>
                    </span>
                </div>
            </div>

        </div>

        <!-- Supplier Message -->
        <div class="card">

            <h2>Supplier Message</h2>

            <div class="message-box">
                <%= response.message %>
            </div>

            <div class="actions">
                <% if (response.responseStatus === "pending") { %>

                    <a href="/vendor/accept-offer/<%= response._id %>"
                    class="btn btn-accept">

                        Accept Offer

                    </a>

                    <a href="/vendor/reject-offer/<%= response._id %>"
                    class="btn btn-reject">

                        Reject Offer

                    </a>

                <% } %>

                <% if (response.responseStatus === "accepted") { %>

                    <button class="btn btn-accept" disabled>
                        Offer Accepted
                    </button>

                <% } %>

                <% if (response.responseStatus === "rejected") { %>

                    <button class="btn btn-reject" disabled>
                        Offer Rejected
                    </button>

                <% } %>

                <a href="tel:<%= response.supplierPhone %>"
                class="btn btn-contact">

                    Contact Supplier

                </a>

                <a href="/vendor/my-requirements"
                class="btn btn-back">

                    Back

                </a>

            </div>

        </div>

    </div>

</body>
</html>