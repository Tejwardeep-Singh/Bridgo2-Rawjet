    <!-- Main Content -->
    <main>
        <div id="page1">
            <section class="landing-container">
                <h1><span>B</span>
                    <span>R</span>
                    <span>I</span>
                    <span>D</span>
                    <span>G</span>
                    <span>O</span>
                </h1>
                <p>Bridging the gap between street food vendors and suppliers. Join us to connect, grow, and thrive together!</p>
                <div class="landing-buttons">
                    <a href="/vendor/login">Vendor Login</a>
                    <a href="/supplier/login" class="supplier">Supplier Login</a>
                </div>
            </section>
        </div>
        <!-- How It Works Section -->
<section class="how-it-works">
    <div class="section-container">
        <h2>How Bridgo Works</h2>
        <p class="section-subtitle">Connecting the local ecosystem in three simple steps.</p>
        
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon">🔍</div>
                <h3>Browse Suppliers</h3>
                <p>Vendors can find local suppliers with fresh ingredients at competitive wholesale prices.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🤝</div>
                <h3>Direct Connection</h3>
                <p>Eliminate middlemen. Chat directly with partners to negotiate and finalize orders.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">📈</div>
                <h3>Grow Together</h3>
                <p>Suppliers expand their reach while vendors lower their costs and improve quality.</p>
            </div>
        </div>
    </div>
</section>
<section class="benefits-section">
    <div class="benefits-container">
        <div class="benefits-content">
            <span class="badge">Why Bridgo?</span>
            <h2>Better Business for <span class="highlight">Everyone.</span></h2>
            <p>We provide the tools street food entrepreneurs need to scale and the platform suppliers need to reach a massive local market.</p>
            
            <div class="benefit-list">
                <div class="benefit-item">
                    <div class="benefit-check">✓</div>
                    <div>
                        <h4>Real-time Auctions</h4>
                        <p>Get the best market prices through our competitive bidding system.</p>
                    </div>
                </div>
                <div class="benefit-item">
                    <div class="benefit-check">✓</div>
                    <div>
                        <h4>Verified Partners</h4>
                        <p>Every vendor and supplier on Bridgo is vetted for quality and reliability.</p>
                    </div>
                </div>
                <div class="benefit-item">
                    <div class="benefit-check">✓</div>
                    <div>
                        <h4>Supply Analytics</h4>
                        <p>Track your requirements and manage your stock more efficiently.</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="benefits-visual">
            <div class="stats-card">
                <div class="stat">
                    <h3>500+</h3>
                    <p>Active Vendors</p>
                </div>
                <div class="stat">
                    <h3>200+</h3>
                    <p>Local Suppliers</p>
                </div>
                <div class="stat">
                    <h3>₹1M+</h3>
                    <p>Monthly Trade</p>
                </div>
            </div>
        </div>
    </div>
</section>
    </main>

    <!-- Footer -->
    <footer class="footer">
    <div class="footer-container">
        <div class="footer-brand">
            <img src="/images/logo.png" alt="Bridgo Logo">
            <p>Empowering street food entrepreneurs through seamless supply chain solutions.</p>
        </div>
        <div class="footer-links">
            <div class="footer-column">
                <h3>Platform</h3>
                <a href="/vendor/login">For Vendors</a>
                <a href="/supplier/login">For Suppliers</a>
