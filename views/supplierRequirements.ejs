<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png">
    <link rel="manifest" href="/favicon/site.webmanifest">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="stylesheet" href="/stylesheets/supplierRequirementsView.css">
    <title>Vendor Requirements - Supplier - Bridgo</title>
</head>
<body>
    <nav class="navbar">
        <div class="nav-container">
            <div class="nav-left">
                <a href="/" class="nav-logo">
                    <img src="/images/logo.png" alt="Bridgo Logo">
                </a>
            </div>
            <div class="nav-right">
                <ul class="nav-menu">
                    <li><a href="/">Home</a></li>
                    <!-- <li><a href="/vendor/login">Vendor</a></li>
                    <li><a href="/supplier/login" class="active">Supplier</a></li> -->
                    <li><button class="dark-mode-toggle" id="darkModeToggle" title="Toggle dark mode">
                    <span id="darkModeIcon">🌙</span>
                </button></li>
                </ul>
            </div>
            <div class="hamburger">
                <span></span>
                <span></span>
                <span></span>
            </div>
        </div>
    </nav>

    <main>
        <div class="container">
            <div class="header">
                <h1>📋 Vendor Requirements</h1>
                <p>Welcome, <strong><%= supplier.name %></strong>! View and respond to vendor requirements.</p>
                
            </div>
            
            <a href="/supplier" class="dashboard-btn">
                <span style="font-size:1.3em;">🏠</span> Back to Dashboard
            </a>

            <% if (success) { %>
                <div class="success-message">
                    ✅ Your response has been submitted successfully!
                </div>
            <% } %>
            
            <% if (requirements && requirements.length > 0) { %>
                <div class="requirements-grid">
                    <% requirements.forEach(requirement => { %>
                        <div class="requirement-card">
                            <div class="requirement-header">
                                <h3><%= requirement.itemName %></h3>
                                <div class="requirement-meta">
                                    Posted on <%= new Date(requirement.createdAt).toLocaleDateString() %>
                                </div>
                            </div>
                            <div class="requirement-content">
                                <div class="requirement-details">
                                    <div class="detail-item">
                                        <span class="detail-label">Requirement:</span>
                                        <span class="detail-value"><%= requirement.requirement %></span>
                                    </div>
                                    <div class="detail-item">
                                        <span class="detail-label">Quantity:</span>
                                        <span class="detail-value"><%= requirement.quantity %></span>
                                    </div>
                                    <div class="detail-item">
                                        <span class="detail-label">Other Details:</span>
                                        <span class="detail-value"><%= requirement.other || 'N/A' %></span>
                                    </div>
                                </div>
                                
                                <div class="vendor-info">
                                    <h4>Vendor Information</h4>
                                    <div class="vendor-details">
                                        <div class="vendor-detail">
                                            <span>Name:</span>
                                            <span><%= requirement.vendorName %></span>
                                        </div>
                                        <div class="vendor-detail">
                                            <span>Phone:</span>
                                            <span><%= requirement.vendorPhone %></span>
                                        </div>
                                        <div class="vendor-detail">
                                            <span>Email:</span>
                                            <span><%= requirement.vendorEmail %></span>
                                        </div>
                                        <div class="vendor-detail">
                                            <span>Address:</span>
                                            <span><%= requirement.vendorAddress %></span>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="response-form">
                                    <h4>Respond to this Requirement</h4>
                                    <form action="/supplier/respond-requirement" method="POST">
                                        <input type="hidden" name="requirementId" value="<%= requirement._id %>">
                                        <div class="form-group">
                                            <label for="message">Your Response:</label>
                                            <textarea name="message" id="message" required placeholder="Describe how you can fulfill this requirement..."></textarea>
                                        </div>
                                        <div class="form-row">
                                            <div class="form-group">
                                                <label for="proposedPrice">Proposed Price (₹):</label>
                                                <input type="number" name="proposedPrice" id="proposedPrice" required min="0" step="0.01" placeholder="Enter your proposed price">
                                            </div>
                                            <div class="form-group">
                                                <label for="proposedQuantity">Proposed Quantity:</label>
                                                <input type="number" name="proposedQuantity" id="proposedQuantity" required min="1" placeholder="Enter quantity you can supply">
                                            </div>
                                        </div>
                                        <button type="submit" class="submit-btn">Send Response</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="no-requirements">
                    <h2>No Pending Requirements</h2>
                    <p>There are currently no vendor requirements to respond to. Check back later!</p>
                </div>
            <% } %>
        </div>
    </main>

   <div class="footer-bottom">
            <p>&copy; 2026 Team Rawjet. All rights reserved.</p>
        </div>

    <script>
        // Mobile menu toggle
        const hamburger = document.querySelector('.hamburger');
        const navMenu = document.querySelector('.nav-menu');
        
        hamburger.addEventListener('click', () => {
            navMenu.classList.toggle('active');
        });
        
        // Close mobile menu when clicking on a link
        document.querySelectorAll('.nav-menu a').forEach(link => {
            link.addEventListener('click', () => {
                navMenu.classList.remove('active');
            });
        });

        // Dark mode toggle
        const darkModeToggle = document.getElementById('darkModeToggle');
        const darkModeIcon = document.getElementById('darkModeIcon');
        function setDarkMode(enabled) {
            if (enabled) {
                document.body.classList.add('dark-mode');
                darkModeIcon.textContent = '☀️';
            } else {
                document.body.classList.remove('dark-mode');
                darkModeIcon.textContent = '🌙';
            }
        }
        // Load preference
        const darkPref = localStorage.getItem('darkMode') === 'true';
        setDarkMode(darkPref);
        darkModeToggle.addEventListener('click', () => {
            const enabled = !document.body.classList.contains('dark-mode');
            setDarkMode(enabled);
            localStorage.setItem('darkMode', enabled);
        });
    </script>
</body>
</html> 